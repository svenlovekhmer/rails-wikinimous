<div class="container py-5">
  <div class="card shadow-sm border-0">
    <div class="card-body p-4">

      <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
          <h1 class="h3 mb-2"><%= @article.title %></h1>
        </div>

        <%= link_to "Edit", edit_article_path(@article), class: "btn btn-outline-primary btn-sm" %>
      </div>

      <div class="mb-4">
        <h2 class="h6 text-muted text-uppercase">Article content</h2>
        <p class="lead mb-0"><%= @article.content %></p>
      </div>

      <%= link_to "← Back to article list", articles_path, class: "btn btn-secondary" %>

    </div>
  </div>
</div>
